    "autoprefixer": "^10.4.5",
    "gatsby-plugin-postcss": "^5.12.1",
    "gh-pages": "^3.2.3",
    "postcss": "^8.4.12",
    "tailwindcss": "^3.0.24",
    "typescript": "^4.6.3"
